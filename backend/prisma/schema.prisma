generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserType {
  HR
  CANDIDATE
}

model User{
  id  String  @id @default(uuid())
  name String
  email String @unique
  password String
  type UserType @default(CANDIDATE)
  profileUrl String?
  bio String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}